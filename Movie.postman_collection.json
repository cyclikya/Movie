          "name": "[1] Registration",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/registration",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "registration"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user1@mail.ru\",\n  \"password\": \"123456\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const d = pm.response.json();",
                  "if (d.accessToken) pm.collectionVariables.set('token1', d.accessToken);",
                  "if (d.user) pm.collectionVariables.set('userId1', d.user.id);"
                ]
              }
            }
          ]
        },
